# NarraOS environment configuration.
# Copy this file to .env and fill in real values locally. Never commit .env.
# Secrets are referenced by NAME only from config/providers.*.yaml, per
# PROVIDER_ARCHITECTURE.md section 15 -- values live only in .env / your secrets manager.

# --- Application -----------------------------------------------------------
NARRAOS_ENVIRONMENT=local
NARRAOS_LOG_LEVEL=INFO

# --- Database / Cache (Foundation Services, PROJECT_ARCHITECTURE.md section 6) ----
NARRAOS_DATABASE_URL=postgresql+asyncpg://narraos:narraos@localhost:5432/narraos
NARRAOS_REDIS_URL=redis://localhost:6379/0

# --- Provider credentials ---------------------------------------------------
# Vendor selections in config/providers.base.yaml as of 2026-07-19 (free tier /
# rate limit research -- see comments in that file for caveats on commercial
# use rights and regional restrictions). Still commented out on purpose: an
# unset credential should fail loudly at provider initialize() time, not
# silently resolve to an empty string. No implementation exists yet for any
# of these -- providers/*/implementations/ is empty until Core Infrastructure.
#
# LLM -- Google AI Studio (primary) + Groq (fallback), both genuinely free,
# no credit card required.
# NARRAOS_LLM_GOOGLE_GEMINI_API_KEY=
# NARRAOS_LLM_GROQ_API_KEY=
#
# Image -- Google AI Studio image generation (primary). Pollinations.ai
# (fallback) needs no key at all.
# NARRAOS_IMAGE_GOOGLE_GEMINI_API_KEY=
#
# TTS -- Piper runs locally, no key needed. Google Cloud TTS (fallback) needs
# a service-account key, not a simple API key -- see Google Cloud IAM docs.
# NARRAOS_TTS_GOOGLE_CLOUD_CREDENTIALS_PATH=
#
# Storage -- Cloudflare R2 (S3-compatible).
# NARRAOS_STORAGE_R2_ACCOUNT_ID=
# NARRAOS_STORAGE_R2_ACCESS_KEY_ID=
# NARRAOS_STORAGE_R2_SECRET_ACCESS_KEY=

# --- YouTube plugin credentials (YOUTUBE_ADAPTER_ARCHITECTURE.md) ----------
# NARRAOS_YOUTUBE_CLIENT_ID=
# NARRAOS_YOUTUBE_CLIENT_SECRET=
# NARRAOS_YOUTUBE_REFRESH_TOKEN=
